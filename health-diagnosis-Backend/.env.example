PORT=3001
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SENDER=your-email@gmail.com
JWT_SECRET=your-secret-key-here

# Google Gemini API (free, lấy tại https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key

# NewsData.io (free: 200 req/ngày, lấy tại https://newsdata.io/register)
NEWSDATA_API_KEY=your-newsdata-api-key

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=health_diagnosis_db

# WHO ICD-11 API
WHO_ICD_CLIENT_ID=your-who-icd-client-id
WHO_ICD_CLIENT_SECRET=your-who-icd-client-secret

# Redis (dùng cho rate limiter - cần khi scale nhiều instances)
REDIS_URL=redis://localhost:6379
